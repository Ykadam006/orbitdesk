# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/orbitdesk"

# Auth.js (generate with: openssl rand -base64 32)
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Socket.IO server
CLIENT_URL="http://localhost:3000"
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# Optional: Claude API for AI board summaries
ANTHROPIC_API_KEY=""

# Optional: Email via Resend (https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="OrbitDesk <noreply@yourdomain.com>"

# Optional: Upstash Redis for distributed rate limiting
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional: Sentry error monitoring
SENTRY_DSN=""

# Set to "true" when behind a trusted reverse proxy (nginx, Vercel, etc.)
TRUST_PROXY="false"

# Prisma connection pool size (default 10)
DATABASE_CONNECTION_LIMIT="10"
